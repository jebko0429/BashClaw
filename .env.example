# Bashclaw environment configuration
# Copy this file to ~/.bashclaw/.env and fill in your values

# AI Provider API Keys (set at least one)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=...
# LONGCAT_API_KEY=...
# FYRA_API_KEY=...
# BIGMODEL_API_KEY=...

# Channel tokens (optional)
# BASHCLAW_TELEGRAM_TOKEN=
# BASHCLAW_DISCORD_TOKEN=
# BASHCLAW_SLACK_TOKEN=
# BASHCLAW_SLACK_WEBHOOK_URL=

# Watchdog tuning (optional)
# WATCHDOG_CHECK_INTERVAL=5
# WATCHDOG_RESTART_BACKOFF_BASE=2
# WATCHDOG_RESTART_BACKOFF_MAX=60
# WATCHDOG_FAIL_WINDOW=300
# WATCHDOG_FAIL_THRESHOLD=5
# WATCHDOG_COOLDOWN_SECONDS=300
# WATCHDOG_STABLE_RESET_SECONDS=600
