#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: switch-codex-account [--api-key] [--device-auth] [-h|--help]

Logs out of the current Codex account if one is active, then starts a new login flow.

Options:
  --api-key      Login with API key from stdin
  --device-auth  Login with device auth flow
  -h, --help     Show this help

Examples:
  switch-codex-account
  switch-codex-account --device-auth
  printenv OPENAI_API_KEY | switch-codex-account --api-key
EOF
}

require_codex() {
  if ! command -v codex >/dev/null 2>&1; then
    printf 'Error: codex command not found in PATH.\n' >&2
    exit 1
  fi
}

login_status() {
  codex login status 2>/dev/null || true
}

has_active_login() {
  local status
  status="$(login_status)"
  if [[ -n "$status" ]] && [[ "$status" != *"Not logged in"* ]]; then
    return 0
  fi
  return 1
}

main() {
  local login_mode=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --api-key)
        login_mode="api_key"
        shift
        ;;
      --device-auth)
        login_mode="device_auth"
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        printf 'Error: unknown option: %s\n\n' "$1" >&2
        usage >&2
        exit 1
        ;;
    esac
  done

  require_codex

  local status
  status="$(login_status)"
  if [[ -n "$status" ]]; then
    printf '%s\n' "$status"
  fi

  if has_active_login; then
    printf 'Logging out of current Codex account...\n'
    codex logout
  else
    printf 'No active Codex login found.\n'
  fi

  printf 'Starting new Codex login...\n'
  case "$login_mode" in
    api_key)
      codex login --with-api-key
      ;;
    device_auth)
      codex login --device-auth
      ;;
    *)
      codex login
      ;;
  esac
}

main "$@"
